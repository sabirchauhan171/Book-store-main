<!DOCTYPE html>
<html>
<head>
    <title>Add Book</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Segoe UI',sans-serif;
        }

        body{
            background:#F8F5F0;
            min-height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            padding:40px 20px;
        }

        .container{
            width:100%;
            max-width:700px;
        }

        .header{
            text-align:center;
            margin-bottom:20px;
        }

        .header h2{
            color:#7F1D1D;
            font-size:34px;
            margin-bottom:8px;
        }

        .header p{
            color:#6B7280;
            font-size:15px;
        }

        .back-link{
            display:inline-block;
            margin-bottom:15px;
            color:#7F1D1D;
            text-decoration:none;
            font-weight:600;
        }

        .back-link:hover{
            text-decoration:underline;
        }

        form{
            background:#FFFFFF;
            padding:35px;
            border-radius:14px;
            border-top:6px solid #7F1D1D;
            box-shadow:0 10px 30px rgba(0,0,0,0.08);
        }

        label{
            display:block;
            margin-top:18px;
            margin-bottom:8px;
            font-size:14px;
            font-weight:600;
            color:#374151;
        }

        input,
        textarea,
        select{
            width:100%;
            padding:13px 15px;
            border:1px solid #D6D3D1;
            border-radius:8px;
            font-size:14px;
            background:#FAFAF9;
            transition:.3s;
        }

        input:focus,
        textarea:focus,
        select:focus{
            outline:none;
            border-color:#7F1D1D;
            box-shadow:0 0 0 4px rgba(127,29,29,.10);
            background:#fff;
        }

        textarea{
            resize:vertical;
        }

        input[type="file"]{
            padding:10px;
            background:#fff;
        }

        .btn{
            width:100%;
            margin-top:25px;
            padding:14px;
            border:none;
            border-radius:8px;
            background:#7F1D1D;
            color:#fff;
            font-size:15px;
            font-weight:600;
            cursor:pointer;
            transition:.3s;
        }

        .btn:hover{
            background:#5B1414;
        }

        .book-icon{
            text-align:center;
            font-size:45px;
            margin-bottom:10px;
        }

        @media(max-width:768px){

            form{
                padding:25px;
            }

            .header h2{
                font-size:28px;
            }
        }

    </style>
</head>

<body>

<div class="container">

    <div class="header">
        <div class="book-icon">📚</div>
        <h2>Edit Book</h2>
        <p>Update the details of an existing book</p>
    </div>

    <a href="/books" class="back-link">← Back to Book List</a>

    <form action="/books/edit/<%= book._id %>?_method=PUT" method="POST" enctype="multipart/form-data">

        <label>Book Title</label>
        <input type="text" name="title" required>

        <label>Author Name</label>
        <input type="text" name="author" required>

        <label>Category</label>
        <select name="category">
            <option>Finance</option>
            <option>Fiction</option>
            <option>Self-Help</option>
            <option>Technology</option>
            <option>Science</option>
            <option>Other</option>
        </select>

        <label>Price (₹)</label>
        <input type="number" name="price" min="0">

        <label>Quantity</label>
        <input type="number" name="quantity" min="0">

        <label>Description</label>
        <textarea name="description" rows="4"></textarea>

        <label>Book Cover Image</label>
        <input type="file" name="image" accept="image/*">

        <button type="submit" class="btn">
            Save Book
        </button>

    </form>

</div>

</body>
</html>